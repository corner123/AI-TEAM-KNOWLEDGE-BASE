# DeepSeek API. /retrieve, routing, evidence guards and evaluation never call
# the model. /answer may send the question and selected evidence excerpts to
# this external API when the provider is auto/deepseek.
DEEPSEEK_API_KEY=replace-with-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# Safe default: explicitly switch to deepseek only after approving external
# transmission of the question and selected evidence excerpts.
ENGINEERING_GENERATION_PROVIDER=deterministic
ENGINEERING_LLM_TIMEOUT_SECONDS=60
ENGINEERING_LLM_MAX_RETRIES=1
ENGINEERING_LLM_MAX_TOKENS=1800
ENGINEERING_LLM_TEMPERATURE=0.1
ENGINEERING_LLM_THINKING_ENABLED=false

# Legacy demo Milvus connection. The engineering RAG always uses its
# partitioned local FAISS/BM25 index and does not read these variables.
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_base

# Legacy demo embedding models
EMBEDDING_MODEL_PATH=BAAI/bge-large-zh-v1.5
SPARSE_EMBEDDING_MODEL_PATH=BAAI/bge-m3
MULTIMODAL_MODEL_PATH=BAAI/visualized-base

# Engineering RAG embedding and optional reranker
ENGINEERING_EMBEDDING_MODEL_PATH=BAAI/bge-small-zh-v1.5
RERANKER_MODEL_PATH=BAAI/bge-reranker-base
ENGINEERING_RERANK_ENABLED=false

# Data paths
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
EVAL_DATA_DIR=data/eval
ENGINEERING_INDEX_DIR=data/indexes/engineering
ENGINEERING_MANIFEST_PATH=data/manifests/builds/current.json
SOURCE_CATALOG_PATH=data/sources/catalog.yaml

# Independent Mini-Nanobot repository (read-only source and verification target)
MINI_NANOBOT_REPO=../Mini-Nanobot

# Read-only RAG HTTP integration.
# RAG_API_TOKEN configures this RAG server. Copy BASE_URL, the same TOKEN, and
# TIMEOUT into the independent Mini-Nanobot process to enable knowledge.search;
# BASE_URL and TIMEOUT are not consumed by the RAG server itself.
RAG_API_BASE_URL=http://127.0.0.1:8000
RAG_API_TOKEN=
RAG_API_TIMEOUT_SECONDS=15
RAG_UI_PORT=8000

# Logging
LOG_LEVEL=INFO
